# =============================================================================
# Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Core Settings
# -----------------------------------------------------------------------------

# Environment: development | production | test
NODE_ENV=development

# Server port
PORT=8080

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# DATABASE_URL is REQUIRED
# 
# Development (SQLite):
#   DATABASE_URL="file:./dev.db"
#
# Production (PostgreSQL):
#   DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"
#
# Production (MySQL):
#   DATABASE_URL="mysql://user:password@host:3306/dbname"
#
DATABASE_URL="file:./dev.db"

# -----------------------------------------------------------------------------
# Session & Authentication
# -----------------------------------------------------------------------------

# Session lifetime in hours (default: 720 = 30 days)
SESSION_TTL_HOURS=720

# Force secure cookies (default: true in production, false in development)
# Set to "true" if using HTTPS in development
# COOKIE_SECURE=false

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Allowed origins for CORS
# REQUIRED in production, optional in development
# Comma-separated for multiple origins
#
# Development (optional - defaults to localhost):
#   CORS_ORIGIN=http://localhost:5173
#
# Production (required):
#   CORS_ORIGIN=https://yourdomain.com
#   CORS_ORIGIN=https://app.yourdomain.com,https://admin.yourdomain.com
#
# CORS_ORIGIN=http://localhost:5173

# -----------------------------------------------------------------------------
# Optional / Future
# -----------------------------------------------------------------------------

# Custom ping message for health checks
PING_MESSAGE="pong"

# Builder.io public key (for CMS integration)
# VITE_PUBLIC_BUILDER_KEY=your_builder_key

# -----------------------------------------------------------------------------
# Frontend (Vite)
# -----------------------------------------------------------------------------

# Backend API base URL (no trailing slash). Used for all API requests.
# Production: set in .env.production or build env as VITE_API_URL=https://apex-25ft.onrender.com
# Local dev: VITE_API_URL=http://localhost:8080 (or your API port); omit to use fallback
# VITE_API_URL=https://apex-25ft.onrender.com

# Support email shown in app footer (mailto link)
# VITE_SUPPORT_EMAIL=support@yourdomain.com
